# Copy this file to .env and fill in real values. Never commit .env to git.

# Flask session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If left unset, a random key is generated on every server start (sessions won't persist across restarts).
SECRET_KEY=

# Password for the built-in "admin" account, created on first run.
# If left unset, falls back to the default "admin123" (not secure — set this in production).
ADMIN_PASSWORD=
